Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SolvePoissonFourier", "[", "source_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"LapFunK", ",", "phiK", ",", "phiSol"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       RowBox[{"LapFunK", "[", 
        RowBox[{"k1_", ",", "k2_", ",", "k3_"}], "]"}], ":=", 
       RowBox[{"FourierTransform", "[", 
        RowBox[{"source", ",", 
         RowBox[{"{", 
          RowBox[{"q1", ",", "q2", ",", "q3"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"k1", ",", "k2", ",", "k3"}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"phiK", "[", 
        RowBox[{"k1_", ",", "k2_", ",", "k3_"}], "]"}], ":=", 
       RowBox[{
        RowBox[{"-", 
         RowBox[{"LapFunK", "[", 
          RowBox[{"k1", ",", "k2", ",", "k3"}], "]"}]}], "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"k1", "^", "2"}], "+", 
          RowBox[{"k2", "^", "2"}], "+", 
          RowBox[{"k3", "^", "2"}]}], ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"phiSol", "=", 
       RowBox[{"InverseFourierTransform", "[", 
        RowBox[{
         RowBox[{"phiK", "[", 
          RowBox[{"k1", ",", "k2", ",", "k3"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"k1", ",", "k2", ",", "k3"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"q1", ",", "q2", ",", "q3"}], "}"}], ",", 
         RowBox[{"Assumptions", "->", 
          RowBox[{"{", 
           RowBox[{"Element", "[", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"q1", "|", " ", "q2", "|", " ", "q3"}], "}"}], ",", 
             "Reals"}], "]"}], "}"}]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"FullSimplify", "[", "phiSol", "]"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[Phi]ini", "[", 
